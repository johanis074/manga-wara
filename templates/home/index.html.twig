{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <h1>Bienvenue sur notre boutique</h1>

    <section>
        <h2>Nouveaux Produits</h2>
        <div class="products">
            {% for product in newProducts %}
                <div class="product">
                    <img src="{{ product.picture }}" alt="{{ product.name }}">
                    <h3>{{ product.name }}</h3>
                    <p>{{ product.price }} €</p>
                </div>
            {% else %}
                <p>Aucun nouveau produit.</p>
            {% endfor %}
        </div>
    </section>

    <section>
        <h2>Produits Populaires</h2>
        <div class="products">
            {% for product in popularProducts %}
                <div class="product">
                    <img src="{{ product.picture }}" alt="{{ product.name }}">
                    <h3>{{ product.name }}</h3>
                    <p>{{ product.price }} €</p>
                </div>
            {% else %}
                <p>Aucun produit populaire.</p>
            {% endfor %}
        </div>
    </section>

    <section>
        <h2>Meilleures Ventes</h2>
        <div class="products">
            {% for product in bestSellers %}
                <div class="product">
                    <img src="{{ product.picture }}" alt="{{ product.name }}">
                    <h3>{{ product.name }}</h3>
                    <p>{{ product.price }} €</p>
                </div>
            {% else %}
                <p>Aucune meilleure vente.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
