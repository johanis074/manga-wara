{% extends 'base.html.twig' %}

{% block title %}{{ filter | capitalize }} Produits{% endblock %}

{% block body %}
    <h2>{{ filter | capitalize }} Produits</h2>
    <ul class="cards-container">
        {% for product in products %}
            <li class="card">
                    {% set routeName = product.type ~ 's_show' %}
                    <a href="{{ path(routeName, {'id': product.id}) }}">
                        <h3>{{ product.name }}</h3>
                        <img src="{{ asset('uploads/pictureProduct/' ~ product.picture) }}" alt="{{ product.name }}">
                        <p> Prix: {{ product.price }} € </p>
                    </a>
                    <a href="{{ path('cart_add', {type: product.type, id: product.id}) }}" class="add-to-cart">
                        ➕ Ajouter au panier
                    </a>
                </li>
        {% else %}
            <p>Aucun produit trouvé.</p>
        {% endfor %}
    </ul>
{% endblock %}
{% block javascript %}
    {{ parent() }}
{% endblock %}