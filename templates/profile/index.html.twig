{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="dashboard-container">

    <nav class="dashboard-nav">
        <ul>
            <li><a href="#profil">Profil</a></li>
            <li><a href="#securite">Sécurité</a></li>
            <li><a href="#adresse">Adresses</a></li>
            <li><a href="#commandes">Commandes</a></li>
        </ul>
    </nav>

    <div class="dashboard-content">

        <!-- Section Profil -->
        <section id="profil">
            <h2>Profil</h2>
            {{ form_start(profileForm) }}
                {{ form_row(profileForm.pseudo) }}
                {{ form_row(profileForm.pictureUser) }}
                <button type="submit" class="btn">Modifier</button>
            {{ form_end(profileForm) }}
        </section>

        <!-- Section Sécurité -->
        <section id="securite">
            <h2>Sécurité</h2>
            {{ form_start(emailForm) }}
                {{ form_row(emailForm.email) }}
                <button type="submit" class="btn">Modifier l'e-mail</button>
            {{ form_end(emailForm) }}

            <hr>

            {{ form_start(passwordForm) }}
                {{ form_row(passwordForm.current_password) }}
                {{ form_row(passwordForm.new_password.first) }}
                {{ form_row(passwordForm.new_password.second) }}
                <button type="submit" class="btn">Changer le mot de passe</button>
            {{ form_end(passwordForm) }}
        </section>

        <!-- Section Adresse -->
        <section id="adresse">
            <h2>Adresses</h2>
            {{ form_start(addressForm) }}
                <h3>Adresse de facturation</h3>
                {{ form_row(addressForm.billing_address) }}

                <div>
                    {{ form_widget(addressForm.delivery_different) }} 
                    {{ form_label(addressForm.delivery_different) }}
                </div>

                <div id="deliveryAddress" style="display: none;">
                    <h3>Adresse de livraison</h3>
                    {{ form_row(addressForm.delivery_address) }}
                </div>

                <button type="submit" class="btn">Enregistrer</button>
            {{ form_end(addressForm) }}
        </section>

        <!-- Section Commandes -->
        <section id="commandes">
            <h2>Vos commandes (3 derniers mois)</h2>
            {% if orders|length > 0 %}
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Numéro</th>
                            <th>Total</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            <tr>
                                <td>{{ order.createdAt|date('d/m/Y') }}</td>
                                <td>#{{ order.id }}</td>
                                <td>{{ order.total }} €</td>
                                <td>{{ order.status }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div class="pagination-container">
                    {{ knp_pagination_render(orders) }}
                </div>
            {% else %}
                <p>Aucune commande récente.</p>
            {% endif %}
        </section>

    </div>
</div>

<script>
    // Affichage conditionnel adresse de livraison
    const checkbox = document.querySelector('[name="address_form[delivery_different]"]');
    const deliverySection = document.getElementById('deliveryAddress');
    checkbox.addEventListener('change', function () {
        deliverySection.style.display = this.checked ? 'block' : 'none';
    });
</script>
{% endblock %}

