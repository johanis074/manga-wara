{% extends 'base.html.twig' %}

{% block title %}
    {{ book.name }}
{% endblock %}

{% block body %}
    <main class="container-books vue">
    
        <section class="book-show1">
            <div>
                <p>
                    <a href="{{ path('app_home') }}">Accueil</a> /
                    <a href="{{ path('books_index') }}">Mangas</a> /
                    {{ book.name }}
                </p>
                <img src="{{ asset('uploads/pictureProduct/' ~ book.picture) }}" alt="{{ book.name }}"/>
            </div>

            <div>
                <h2>{{ book.name }}</h2>

                <!-- Boutons pour afficher la description ou les détails -->
                <button id="btn-description">Description</button>
                <button id="btn-details">Détails</button>

                <!-- Conteneur qui recevra le contenu -->
                <div id="content-container"></div>

                <!-- Bouton "Ajouter au panier" -->
                <a href="{{ path('cart_add', {type: book.type, id: book.id}) }}" class="add-to-cart" data-id="{{ book.id }}" data-type="{{ book.type }}">
                        ➕ Ajouter au panier
                    </a>
            </div>
        </section>

        <!-- Injection des données sous forme de JSON dans un élément caché -->
        <script type="application/json" id="book-data">
            {
                "synopsis": "{{ book.synopsis|e('js') }}",
                "editor": "{{ book.editor.name|e('js') }}",
                "category": "{{ book.category.name|e('js') }}",
                "reference": "{{ book.reference|e('js') }}",
                "isbn": "{{ book.isbn|e('js') }}",
                "ean": "{{ book.ean|e('js') }}",
                "price": "{{ book.price }}"
            }
        </script>

        <section class="collection">
            <h2>Dans la même collection</h2>

            {% if relatedBooks is not empty %}
                <div class="related-books cards-container">
                    {% for related in relatedBooks %}
                        <div class="related-book-card card">
                            <a href="{{ path('books_show', { id: related.id }) }}">
                                <img src="{{ asset('uploads/pictureProduct/' ~ related.picture) }}" alt="{{ related.name }}" />
                                <h3>{{ related.name }}</h3>
                                <p>{{ related.price }} €</p>
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucun autre produit dans cette collection.</p>
            {% endif %}
        </section>
    <section class="book-show2">
    {# Formulaire pour ajouter un commentaire #}
        {{ form_start(form) }}
            {{ form_row(form.content) }}
            <button type="submit" class="btn btn-success">Envoyer</button>
        {{ form_end(form) }}

    {# Affichage des commentaires #}
        <ul>
            {% for comment in pagination %}
                <li>
                    
                    <p>Posté par: <img src="{{ asset('uploads/pictureUser/' ~ comment.user.pictureUser) }}" alt="image du profil"></img> {{ comment.user.pseudo }}</p>
                    <p>Posté le: {{ comment.date|date('d/m/Y H:i') }}</p>
                    <p>{{ comment.content }}</p>
                </li>
            {% else %}
                <p>Aucun commentaire pour le moment.</p>
            {% endfor %}
        </ul>

    {# Pagination #}
        <div class="pagination">
            {{ knp_pagination_render(pagination) }}
        </div>
    </section>
    {# Lien de retour #}
    
    </main>
{% endblock %}