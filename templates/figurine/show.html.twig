{% extends 'base.html.twig' %}

{% block title %}
    {{ figurine.name }}
{% endblock %}

{% block body %}
    <main class="bg">
    
        <section class="book-show1">
            <div>
                <p>
                    <a href="{{ path('app_home') }}">Accueil</a> /
                    <a href="{{ path('figurines_index') }}">Figurines</a> /
                    {{ figurine.name }}
                </p>
                <img src="{{ asset('uploads/pictureProduct/' ~ figurine.picture) }}" alt="{{ figurine.name }}"/>
            </div>

            <div class="book-bg">
                <h2>{{ figurine.name }}</h2>
                <p>Prix: {{ figurine.price }} €</p>
                <h3>Synopsis</h3>
                <p>{{ figurine.description }}</p>
                <h3>Details</h3>
                <div class="details">
                    <button type="button" class="add-to-cart" data-id="{{ figurine.id }}" data-type="{{ figurine.type }}">
                        ➕ Ajouter au panier
                    </button>
                    <ul>
                        <li>Marque: {{ figurine.brand }}</li>
                        <li>Référence: {{ figurine.reference }}</li>
                        <li>Hauteur: {{ figurine.height }}</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="collection">
            <h2>Dans la même collection</h2>

            {% if relatedFigurines is not empty %}
                <div class="related-books cards-container">
                    {% for related in relatedFigurines %}
                        <div class="related-book-card card">
                            <a href="{{ path('figurines_show', { id: related.id }) }}">
                                <div class="card-header">
                                    <h3 class="figurine-name">{{ related.name }}</h3>
                                    <p class="figurine-brand">{{ related.brand }}</p>
                                </div>
                                <img src="{{ asset('uploads/pictureProduct/' ~ related.picture) }}" alt="{{ related.name }}" />
                                <p>{{ related.price }} €</p>
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucun autre produit dans cette collection.</p>
            {% endif %}
        </section>

        <section class="book-show2">
            <h2>Ajouter un commentaire</h2>
            {% if app.user %}
                {{ form_start(form) }}
                <span>{{ form_row(form.content) }}</span>
                <button type="submit" class="btn btn-success">Envoyer</button>
                {{ form_end(form) }}
            {% else %}
                <p>Vous devez être connecté pour laisser un commentaire.</p>
            {% endif %}

            {% if form is not empty %}
                <h3>Votre commentaire</h3>
            {% endif %}

            <ul>
                {% for comment in pagination %}
                    <li class="comment">
                            {% if comment.user.pictureUser is not null %}
                                <img src="{{ asset('uploads/pictureUser/' ~ comment.user.pictureUser) }}" alt="image du profil">
                            {% else %}
                                <img src="{{ asset('uploads/pictureUser/default.png') }}" alt="image du profil">
                            {% endif %}
                            
                            <div>
                                <div class="comment-user">
                                    <p>Posté par: {{ comment.user.pseudo }} le: {{ comment.date|date('d/m/Y') }} à {{ comment.date|date('H:i') }}</p>
                                </div>
                                <p class="comment-text">{{ comment.content }}</p>
                            
                                    <div class="comment-header">
                                        {% if app.user and (comment.user == app.user or is_granted('ROLE_ADMIN')) %}
                                            <form method="post" action="{{ path('comment_delete', {id: comment.id}) }}" onsubmit="return confirm('Supprimer ce commentaire ?');" style="display:inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                                                <button type="submit" class="btn btn-danger">Supprimer</button>
                                            </form>
                                        {% endif %}
                                    </div>
                        </div>
                        
                    </li>
                {% else %}
                    <p>Aucun commentaire pour le moment.</p>
                {% endfor %}
            </ul>

            <div class="pagination">
                {{ knp_pagination_render(pagination) }}
            </div>
        </section>
    
    </main>
{% endblock %}

{% block javascript %}
    {{ parent() }}
{% endblock %}
