{% extends 'base.html.twig' %}

{% block title %}Ajouter une nouvelle figurine - Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}

{% block body %}
<main class="bg">
    <section class="dashboard-content">
        <h2>Ajouter une nouvelle figurine</h2>

        {# Affichage des flash messages #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger" role="alert">{{ message }}</div>
        {% endfor %}

        {{ form_start(form, {
            'attr': {
                'class': 'needs-validation',
                'novalidate': 'novalidate',
                'enctype': 'multipart/form-data',
                'name': 'figurine'  
            }
        }) }}

        {# Boucle sur les champs à afficher #}
        {% for field in [form.picture, form.name, form.brand, form.description, form.price, form.reference, form.height] %}
            <div class="form-group">
                {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(field, {
                    attr: { class: field.vars.errors|length > 0 ? 'form-control is-invalid' : 'form-control' }
                }) }}

                {% if field.vars.errors|length > 0 %}
                    <div class="invalid-feedback">
                        {% for error in field.vars.errors %}
                            {{ error.message }}<br>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endfor %}

        <button type="submit" class="btn btn-primary mt-3">Enregistrer</button>

        {{ form_end(form) }}
    </section>

    <a href="{{ path('figurines_index') }}" class="btn btn-secondary mt-4">Retour à la liste</a>
</main>
{% endblock %}
