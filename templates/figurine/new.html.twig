{% extends 'base.html.twig' %}

{% block title %}Ajouter une nouvelle figurine - Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}

{% block body %}
<main class="dashboard-container">
    <section class="dashboard-content">
        <h2>Ajouter une nouvelle figurine</h2>

        {# Flash messages #}
        {% if app.session.flashBag.has('success') %}
            <div class="alert alert-success">
                {{ app.session.flashBag.get('success')[0] }}
            </div>
        {% endif %}
        {% if app.session.flashBag.has('error') %}
            <div class="alert alert-danger">
                {{ app.session.flashBag.get('error')[0] }}
            </div>
        {% endif %}

        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

        {# Champs à afficher #}
        {% for field in [form.picture, form.name, form.brand, form.description, form.price, form.reference, form.height] %}
            <div>
                {{ form_label(field) }}
                {{ form_widget(field, {
                    attr: { class: field.vars.errors|length > 0 ? 'error' : '' }
                }) }}

                {% if field.vars.errors|length > 0 %}
                    <div class="form-error-message">
                        {% for error in field.vars.errors %}
                            {{ error.message }}<br>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endfor %}

        <button type="submit" class="btn btn-primary">Enregistrer</button>

        {{ form_end(form) }}
    </section>

    <a href="{{ path('figurines_index') }}" class="btn btn-secondary mt-3">Retour à la liste</a>
</main>
{% endblock %}
