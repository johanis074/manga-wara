{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}
{% block body %}
<main class="bg">
    <section class="admin-container">
        <h2>Liste des utilisateurs</h2>

        {% for user in users %}
            <div class="admin-box half">
                <p><strong>ID :</strong> {{ user.id }}</p>
                <p><strong>Pseudo :</strong> {{ user.pseudo }}</p>
                <p><strong>Rôles :</strong> {{ user.roles | join(', ') }}</p>

                <div style="margin-top: 0.5rem;">
                    <a href="{{ path('admin_user_edit', { id: user.id }) }}"
                       style="color: blue; text-decoration: none; margin-right: 10px;">Modifier</a>

                    <form method="post"
                          action="{{ path('admin_user_delete', { id: user.id }) }}"
                          style="display: inline;"
                          onsubmit="return confirm('Supprimer l’utilisateur {{ user.pseudo }} ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                        <button type="submit"
                                style="color: red; background: none; border: none; cursor: pointer;">
                            Supprimer
                        </button>
                    </form>
                </div>
            </div>
        {% else %}
            <p>Aucun utilisateur trouvé.</p>
        {% endfor %}
    </section>
</main>
{% endblock %}

