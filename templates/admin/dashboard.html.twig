{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
<main class="admin-container">
    <h1 class="admin-title">Tableau de bord Admin</h1>

    <section class="admin-section">
        <!-- Ajouter un admin -->
        <form action="{{ path('admin_register') }}" method="post" class="admin-box half">
            <button type="submit" class="btn-blue">
                ➕ Ajouter un admin
            </button>
        </form>

        <!-- Derniers mangas -->
        <div class="admin-box half">
            <h2>📚 5 derniers mangas</h2>
            <ul>
                {% for book in books %}
                    <li><strong>{{ book.name }}</strong> - {{ book.editor.name }}</li>
                {% else %}
                    <li>Aucun manga trouvé.</li>
                {% endfor %}
            </ul>
            <a href="" class="btn-blue">Voir tous les livres</a>
        </div>

        <!-- Dernières figurines -->
        <div class="admin-box half">
            <h2>🧸 5 dernières figurines</h2>
            <ul>
                {% for figurine in figurines %}
                    <li><strong>{{ figurine.name }}</strong> - {{ figurine.brand.name }}</li>
                {% else %}
                    <li>Aucune figurine trouvée.</li>
                {% endfor %}
            </ul>
            <a href="" class="btn-blue">Voir toutes les figurines</a>
        </div>

        <!-- Derniers utilisateurs -->
        <div class="admin-box half">
            <h2>🧑‍💻 5 derniers utilisateurs</h2>
            <table class="admin-table">
                <thead>
                    <tr><th>ID</th><th>Pseudo</th><th>Email</th></tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr><td>{{ user.id }}</td><td>{{ user.pseudo }}</td><td>{{ user.email }}</td></tr>
                    {% else %}
                        <tr><td colspan="3">Aucun utilisateur</td></tr>
                    {% endfor %}
                </tbody>
            </table>
            <a href="{{ path('admin_users') }}" class="btn-blue">Voir tous les utilisateurs</a>
        </div>

        <!-- Dernières commandes -->
        <div class="admin-box half">
            <h2>🧾 10 dernières commandes</h2>
            <table class="admin-table">
                <thead>
                    <tr><th>ID</th><th>Client</th><th>Statut</th><th>Date</th></tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>{{ order.id }}</td>
                            <td>{{ order.user ? order.user.pseudo : 'Invité' }}</td>
                            <td>{{ order.status.value }}</td>
                            <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4">Aucune commande</td></tr>
                    {% endfor %}
                </tbody>
            </table>
            <a href="{{ path('admin_orders') }}" class="btn-blue">Voir toutes les commandes</a>
        </div>
    </section>
</main>
<style>
/* Conteneur principal */
.admin-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 20px;
    background: #f5f7fa;
    border-radius: 12px;
}

/* Titre principal */
.admin-title {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 30px;
    color: #2c3e50;
    text-align: center;
}

/* Section */
.admin-section {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: space-between;
}

/* Boîte admin */
.admin-box {
    background: #fff;
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.05);
    flex: 1 1 48%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;
}

.admin-box h2 {
    font-size: 1.2rem;
    margin-bottom: 15px;
    color: #34495e;
}

/* Liste */
.admin-box ul {
    list-style: none;
    padding: 0;
    margin-bottom: 15px;
}

.admin-box li {
    padding: 6px 0;
    border-bottom: 1px solid #eee;
    font-size: 0.95rem;
}

/* Tableau */
.admin-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 15px;
}

.admin-table th,
.admin-table td {
    text-align: left;
    padding: 10px;
    border-bottom: 1px solid #ddd;
    font-size: 0.95rem;
}

.admin-table th {
    background-color: #ecf0f1;
    font-weight: bold;
}

/* Bouton */
.btn-blue {
    align-self: flex-start;
    background-color: #3498db;
    color: white;
    padding: 10px 16px;
    text-decoration: none;
    border-radius: 8px;
    transition: background-color 0.3s;
    font-weight: 500;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
}

.btn-blue:hover {
    background-color: #2980b9;
}

/* Responsive */
@media (max-width: 768px) {
    .admin-box {
        flex: 1 1 100%;
    }

    .admin-title {
        font-size: 1.6rem;
    }
}

{% endblock %}







