{% extends 'base.html.twig' %}

{% block title %}Commandes{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}
{% block body %}
<main class="admin-container">
    <h2>Liste des commandes</h2>

    {% for order in orders %}
        <section class="admin-box half">
            <h3>Commande n°{{ order.id }} - {{ order.createdAt|date('d/m/Y H:i') }}</h3>
            <p><strong>Client :</strong> {{ order.user.firstName }} {{ order.user.lastName }}</p>
            <p><strong>Adresse :</strong> {{ order.user.address }}, {{ order.user.postalCode }} {{ order.user.city }}</p>
            <p><strong>Statut :</strong> {{ order.status.value }}</p>

            <h4>Produits commandés :</h4>
            <ul>
                {% for detail in order.products %}
                    <li>
                        {{ detail.name }} — {{ detail.quantity }}
                    </li>
                {% else %}
                    <li>Aucun produit.</li>
                {% endfor %}
            </ul>

            {% if order.status.value != 'Terminé' %}
                <form method="post" action="{{ path('admin_order_next_status', { id: order.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('next_status_' ~ order.id) }}">
                    <button type="submit">➡️ Étape suivante</button>
                </form>
            {% else %}
                <p>✅ Terminé</p>
            {% endif %}
        </section>
    {% else %}
        <p>Aucune commande disponible.</p>
    {% endfor %}
</main>
{% endblock %}
